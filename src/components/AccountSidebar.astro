---
interface Props {
  active: "Account Details" | "Address";
}

const { active } = Astro.props;

const items = [
  { label: "Account Details", href: "/my-account", icon: "user" },
  { label: "Address", href: "/address", icon: "location" },
  { label: "Orders", href: "/my-account", icon: "cart" },
  { label: "Wishlist", href: "/my-account", icon: "heart" },
  { label: "Reports", href: "/my-account", icon: "clock" },
  { label: "Downloads", href: "/my-account", icon: "download" },
  { label: "Support", href: "/my-account", icon: "warning" },
] as const;

const paths = {
  user: "M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5 6a5 5 0 1 1 10 0v1H3v-1Z",
  location: "M8 15s4-4.5 4-8A4 4 0 1 0 4 7c0 3.5 4 8 4 8Zm0-5.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z",
  cart: "M2.5 3h1.8l1.3 6.3h6.2l1.1-4.2H5.2M6.5 13.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm4.8 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z",
  heart: "m8 14-1.2-1.1C4.1 10.4 2.5 9 2.5 6.9A2.9 2.9 0 0 1 5.4 4c1 0 1.9.5 2.6 1.3A3.5 3.5 0 0 1 10.6 4a2.9 2.9 0 0 1 2.9 2.9c0 2.1-1.6 3.5-4.3 6L8 14Z",
  clock: "M8 14a6 6 0 1 0 0-12 6 6 0 0 0 0 12Zm0-9v3.2l2.4 1.4",
  download: "M8 3v7m0 0 2.5-2.5M8 10 5.5 7.5M3 13h10",
  warning: "M8 3.5 13 12H3L8 3.5Zm0 3.3v2.9m0 1.8h.01",
  logout: "M6 5H4.5A1.5 1.5 0 0 0 3 6.5v3A1.5 1.5 0 0 0 4.5 11H6m2-1 2-2m0 0-2-2m2 2H6",
} as const;
---

<aside class="account-sidebar" data-testid="account-sidebar">
  <h2>My Account</h2>
  <ul>
    {items.map((item) => (
      <li>
        <a href={item.href} class={item.label === active ? "account-sidebar__link account-sidebar__link--active" : "account-sidebar__link"}>
          <svg class="account-sidebar__icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d={paths[item.icon]} stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3"/>
          </svg>
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <a class="account-sidebar__logout" href="#" data-open-login-modal="login">
    <svg class="account-sidebar__icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d={paths.logout} stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3"/>
    </svg>
    Logout
  </a>
</aside>
