<section class="checkout" data-testid="checkout-page" data-checkout-page>
  <form class="checkout__form" id="checkout-form">
    <h2>Billing Address</h2>
    <div class="checkout__grid">
      <label>
        First Name *
        <input name="firstName" autocomplete="given-name" required />
      </label>
      <label>
        Last Name *
        <input name="lastName" autocomplete="family-name" required />
      </label>
      <label>
        Country / Region *
        <select name="country" required>
          <option value="">Select a country / region</option>
          <option>United States</option>
          <option>Ukraine</option>
          <option>Canada</option>
        </select>
      </label>
      <label>
        Town / City *
        <input name="city" autocomplete="address-level2" required />
      </label>
      <label>
        Street Address *
        <input name="street1" placeholder="House number and street name" autocomplete="address-line1" required />
        <input name="street2" placeholder="Apartment, suite, unit, etc. (optional)" autocomplete="address-line2" />
      </label>
      <label>
        State *
        <select name="state" required>
          <option value="">Select a state</option>
          <option>New York</option>
          <option>California</option>
          <option>Florida</option>
        </select>
      </label>
      <label>
        Zip *
        <input name="zip" autocomplete="postal-code" required />
      </label>
      <label>
        Phone Number *
        <input name="phone" type="tel" placeholder="Phone number" autocomplete="tel" required />
      </label>
      <label>
        Email address *
        <input name="email" type="email" autocomplete="email" required />
      </label>
    </div>

    <label class="checkout__ship-toggle">
      <input type="checkbox" name="shipDifferent" data-ship-toggle />
      Ship to a different address?
    </label>

    <div class="checkout__grid checkout__shipping" data-ship-fields hidden>
      <label>
        Shipping first name *
        <input name="shipFirstName" />
      </label>
      <label>
        Shipping last name *
        <input name="shipLastName" />
      </label>
      <label>
        Shipping address *
        <input name="shipAddress" />
      </label>
      <label>
        Shipping city *
        <input name="shipCity" />
      </label>
    </div>

    <label class="checkout__notes">
      Order notes (optional)
      <textarea name="notes" rows="4"></textarea>
    </label>
  </form>

  <aside class="checkout__summary">
    <h2>Your Order</h2>
    <div class="checkout__head">
      <strong>Products</strong>
      <strong>Subtotal</strong>
    </div>

    <ul class="checkout__items" data-checkout-items>
      <li class="checkout__item"><span>Loading...</span></li>
    </ul>

    <div class="cart__line"><span>Subtotal</span><strong data-checkout-subtotal>$0.00</strong></div>
    <div class="cart__line"><span>Coupon Discount</span><strong>(-) $00.00</strong></div>
    <div class="cart__line"><span>Shipping</span><strong data-checkout-shipping>$0.00</strong></div>
    <a class="checkout__shipping-link" href="/cart">View shipping charge</a>
    <div class="cart__line cart__line--total"><span>Total</span><strong data-checkout-total>$0.00</strong></div>

    <fieldset class="checkout__payments" data-payment-group>
      <legend>Payment Method</legend>
      <label class="checkout__pay checkout__pay--logos">
        <input type="radio" name="payment" value="paypal" />
        <img src="/assets/figma-all/images/image-16-5-2414.png" alt="PayPal, MasterCard, VISA and American Express" width="224" height="26" />
      </label>
      <label class="checkout__pay">
        <input type="radio" name="payment" value="bank" />
        Direct bank transfer
      </label>
      <label class="checkout__pay checkout__pay--active">
        <input type="radio" name="payment" value="cod" checked />
        Cash on delivery
      </label>
    </fieldset>

    <button class="c-button checkout__place-order" type="submit" form="checkout-form">Place Order</button>
  </aside>
</section>

<script is:inline>
  (() => {
    const init = () => {
      const root = document.querySelector("[data-checkout-page]");
      const form = document.getElementById("checkout-form");
      if (!root || !form || !window.GreenShopCart) return false;

      const shipToggle = form.querySelector("[data-ship-toggle]");
      const shipFields = form.querySelector("[data-ship-fields]");
      const paymentGroup = root.querySelector("[data-payment-group]");
      const paymentLabels = Array.from(root.querySelectorAll(".checkout__pay"));
      const itemsList = root.querySelector("[data-checkout-items]");
      const subtotalEl = root.querySelector("[data-checkout-subtotal]");
      const shippingEl = root.querySelector("[data-checkout-shipping]");
      const totalEl = root.querySelector("[data-checkout-total]");

      const money = (value) => `$${Number(value || 0).toFixed(2)}`;

      const renderItems = () => {
        const items = window.GreenShopCart.getDetailedItems();
        const totals = window.GreenShopCart.getTotals();
        if (subtotalEl) subtotalEl.textContent = money(totals.subtotal);
        if (shippingEl) shippingEl.textContent = money(totals.shipping);
        if (totalEl) totalEl.textContent = money(totals.total);

        if (!itemsList) return;
        if (!items.length) {
          itemsList.innerHTML = `<li class="checkout__item"><span>Cart is empty. Add products from shop.</span></li>`;
          return;
        }

        itemsList.innerHTML = items
          .map(
            (item) => `
            <li class="checkout__item">
              <div class="checkout__item-product">
                <img src="${item.image}" alt="${item.name}" width="70" height="70" />
                <div>
                  <p>${item.name}</p>
                  <span>SKU: ${item.sku}</span>
                </div>
              </div>
              <strong>${money(item.total)}</strong>
            </li>
          `
          )
          .join("");
      };

      shipToggle?.addEventListener("change", () => {
        const enabled = shipToggle.checked;
        if (shipFields) {
          shipFields.hidden = !enabled;
          shipFields.querySelectorAll("input").forEach((input) => {
            input.required = enabled;
          });
        }
      });

      paymentGroup?.addEventListener("change", () => {
        paymentLabels.forEach((label) => label.classList.remove("checkout__pay--active"));
        const checked = paymentGroup.querySelector("input[name='payment']:checked");
        checked?.closest(".checkout__pay")?.classList.add("checkout__pay--active");
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const items = window.GreenShopCart.getDetailedItems();
        if (!items.length) {
          alert("Your cart is empty. Add products first.");
          return;
        }

        const totals = window.GreenShopCart.getTotals();
        const customer = Object.fromEntries(new FormData(form).entries());
        const payment =
          root.querySelector("input[name='payment']:checked")?.value || "cod";
        const payload = {
          customer: { ...customer, payment },
          items,
          totals,
          createdAt: new Date().toISOString(),
        };

        if (window.GreenShopDB?.enabled) {
          try {
            const remote = await window.GreenShopDB.createOrder(payload);
            if (remote?.orderId) payload.remoteOrderId = remote.orderId;
          } catch (error) {
            console.error("Order sync failed:", error);
          }
        }

        localStorage.setItem("greenshop-last-order", JSON.stringify(payload));
        window.GreenShopCart.clear();
        window.location.href = "/order-confirmation";
      });

      window.addEventListener("greenshop:cart-change", renderItems);
      renderItems();
      return true;
    };

    if (!init()) {
      window.addEventListener("DOMContentLoaded", init, { once: true });
    }
  })();
</script>
