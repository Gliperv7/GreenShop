---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CheckoutPanel from "../components/CheckoutPanel.astro";
---

<Layout
  title="Order Confirmation | GreenShop"
  description="Your GreenShop order has been successfully placed."
  pathname="/order-confirmation"
>
  <div class="l-container l-stack order-confirmation-page">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Shop", href: "/shop" }, { label: "Order confirmation" }]} />
    <div class="order-confirmation-page__base">
      <CheckoutPanel />
    </div>
    <section class="order-done order-done--modal" data-testid="order-confirmation-page">
      <img src="/assets/logo.svg" alt="Order confirmation icon" width="70" height="70" />
      <h1>Your order is confirmed</h1>
      <p class="section-heading__text">Thank you. Your order has been received.</p>
      <div class="order-done__grid">
        <p><strong>Order Number:</strong> 19586687</p>
        <p><strong>Date:</strong> March 5, 2026</p>
        <p><strong>Total:</strong> $2,699.00</p>
        <p><strong>Payment Method:</strong> Cash on delivery</p>
      </div>
      <a class="c-button" href="/shop">Track your order</a>
    </section>
  </div>
</Layout>
